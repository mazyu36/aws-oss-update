---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AWS 関連 OSS リリースの解説サイト' } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | AWS OSS Release Notes</title>
    <link rel="alternate" type="application/rss+xml" title="AWS OSS リリース解説" href={`${baseUrl}rss.xml`} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style is:global>
      :root {
        --color-bg: #0a0a0b;
        --color-bg-elevated: #111113;
        --color-bg-card: #18181b;
        --color-border: #27272a;
        --color-border-subtle: #1f1f23;
        --color-text: #fafafa;
        --color-text-muted: #d4d4d8;
        --color-text-subtle: #a1a1aa;
        --color-accent: #94a3b8;
        --color-accent-dim: #64748b;
        --color-accent-glow: rgba(148, 163, 184, 0.15);
        --color-success: #22c55e;
        --color-prerelease: #f59e0b;
        --color-python: #10b981;
        --color-typescript: #10b981;
        --color-tools: #10b981;
        --color-agentcore-python: #a78bfa;
        --color-agentcore-typescript: #a78bfa;
        --color-cdk: #fb923c;
        --font-display: 'Outfit', sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
        --radius-sm: 6px;
        --radius-md: 12px;
        --radius-lg: 20px;
        --shadow-glow: 0 0 60px rgba(16, 185, 129, 0.08);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-display);
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.7;
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
      }

      /* Subtle grid background */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(16, 185, 129, 0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(16, 185, 129, 0.02) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: -1;
      }

      /* Gradient orb */
      body::after {
        content: '';
        position: fixed;
        top: -200px;
        right: -200px;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, var(--color-accent-glow) 0%, transparent 70%);
        pointer-events: none;
        z-index: -1;
      }

      a {
        color: var(--color-accent);
        text-decoration: none;
        transition: all 0.2s ease;
      }

      a:hover {
        color: var(--color-text);
      }

      ::selection {
        background: var(--color-accent);
        color: var(--color-bg);
      }

      code {
        font-family: var(--font-mono);
        font-size: 0.9em;
        background: var(--color-bg-elevated);
        padding: 0.2em 0.4em;
        border-radius: var(--radius-sm);
        border: 1px solid var(--color-border-subtle);
        font-variant-ligatures: none;
      }

      pre {
        font-family: var(--font-mono);
        background: var(--color-bg-elevated);
        padding: 1.5rem;
        border-radius: var(--radius-md);
        overflow-x: auto;
        border: 1px solid var(--color-border-subtle);
        position: relative;
        font-variant-ligatures: none;
      }

      pre code {
        background: none;
        padding: 0;
        border: none;
        font-size: 0.85rem;
        line-height: 1.6;
      }

      .code-block-wrapper {
        position: relative;
        margin: 1.5rem 0;
      }

      .copy-button {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        padding: 0.4rem 0.75rem;
        font-size: 0.75rem;
        font-family: var(--font-mono);
        background: var(--color-bg-card);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        color: var(--color-text-muted);
        cursor: pointer;
        transition: all 0.2s ease;
        z-index: 10;
      }

      .copy-button:hover {
        background: var(--color-bg-elevated);
        color: var(--color-text);
        border-color: var(--color-accent-dim);
      }

      .copy-button.copied {
        background: var(--color-success);
        border-color: var(--color-success);
        color: var(--color-bg);
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="header-content">
        <div class="header-left">
          <slot name="header-left" />
          <a href={baseUrl} class="home-link" aria-label="Home" title="ホーム">
            <i class="fa-solid fa-house"></i>
          </a>
          <a href={`${baseUrl}rss.xml`} class="rss-link" aria-label="RSS Feed" title="RSSで購読">
            <i class="fa-solid fa-rss"></i>
          </a>
        </div>
        <nav class="nav">
          <div class="github-links">
            <a href="https://github.com/strands-agents" target="_blank" rel="noopener" class="github-badge" title="Strands Agents">
              <svg class="github-icon" viewBox="0 0 16 16" fill="currentColor" width="16" height="16">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
              </svg>
              <span class="github-repo">strands-agents</span>
            </a>
            <a href="https://github.com/aws/bedrock-agentcore-sdk-python" target="_blank" rel="noopener" class="github-badge github-badge-agentcore" title="Bedrock AgentCore SDK Python">
              <svg class="github-icon" viewBox="0 0 16 16" fill="currentColor" width="16" height="16">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
              </svg>
              <span class="github-repo">AgentCore Python</span>
            </a>
            <a href="https://github.com/aws/bedrock-agentcore-sdk-typescript" target="_blank" rel="noopener" class="github-badge github-badge-agentcore" title="Bedrock AgentCore SDK TypeScript">
              <svg class="github-icon" viewBox="0 0 16 16" fill="currentColor" width="16" height="16">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
              </svg>
              <span class="github-repo">AgentCore TypeScript</span>
            </a>
            <a href="https://github.com/aws/aws-cdk" target="_blank" rel="noopener" class="github-badge github-badge-cdk" title="AWS CDK">
              <svg class="github-icon" viewBox="0 0 16 16" fill="currentColor" width="16" height="16">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
              </svg>
              <span class="github-repo">AWS CDK</span>
            </a>
          </div>
        </nav>
      </div>
    </header>

    <main class="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-content">
        <p class="footer-text">
          AWS OSS Release Notes
        </p>
      </div>
    </footer>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const codeBlocks = document.querySelectorAll('pre');

        codeBlocks.forEach((pre) => {
          if (pre.parentElement?.classList.contains('code-block-wrapper')) {
            return;
          }

          const wrapper = document.createElement('div');
          wrapper.className = 'code-block-wrapper';
          pre.parentNode?.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);

          const button = document.createElement('button');
          button.className = 'copy-button';
          button.textContent = 'Copy';
          button.setAttribute('aria-label', 'Copy code to clipboard');

          button.addEventListener('click', async () => {
            const code = pre.querySelector('code')?.textContent || pre.textContent || '';

            try {
              await navigator.clipboard.writeText(code);
              button.textContent = 'Copied!';
              button.classList.add('copied');

              setTimeout(() => {
                button.textContent = 'Copy';
                button.classList.remove('copied');
              }, 2000);
            } catch (err) {
              console.error('Failed to copy:', err);
              button.textContent = 'Failed';
              setTimeout(() => {
                button.textContent = 'Copy';
              }, 2000);
            }
          });

          wrapper.appendChild(button);
        });
      });
    </script>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 11, 0.8);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .header-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .home-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    font-size: 0.9rem;
    color: var(--color-accent);
    transition: all 0.2s ease;
  }

  .home-link:hover {
    border-color: var(--color-accent-dim);
    color: var(--color-accent);
    background: var(--color-bg-elevated);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--color-text);
  }

  .logo:hover {
    color: var(--color-text);
  }

  .logo-icon {
    color: var(--color-accent);
    font-size: 1rem;
  }

  .logo-accent {
    color: var(--color-accent);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .rss-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    font-size: 0.9rem;
    color: var(--color-accent);
    transition: all 0.2s ease;
  }

  .rss-link:hover {
    border-color: var(--color-accent-dim);
    color: var(--color-accent);
    background: var(--color-bg-elevated);
  }

  .github-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    transition: all 0.2s ease;
  }

  .github-badge:hover {
    border-color: var(--color-accent-dim);
    color: var(--color-text);
    background: var(--color-bg-elevated);
  }

  .github-icon {
    flex-shrink: 0;
  }

  .github-repo {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
  }

  .github-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .github-badge-agentcore:hover {
    border-color: var(--color-agentcore-python);
  }

  .github-badge-cdk:hover {
    border-color: var(--color-cdk);
  }

  .main-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    min-height: calc(100vh - 200px);
  }

  .site-footer {
    border-top: 1px solid var(--color-border-subtle);
    padding: 2rem;
    margin-top: 4rem;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-text {
    font-size: 0.8rem;
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .header-content {
      padding: 1rem 1rem;
    }

    .logo-text {
      font-size: 0.9rem;
    }

    .github-badge {
      padding: 0.4rem 0.5rem;
      gap: 0.35rem;
    }

    .github-repo {
      display: none;
    }

    .github-links {
      gap: 0.35rem;
    }
  }

  @media (max-width: 480px) {
    .nav {
      gap: 0.5rem;
    }

    .logo-text {
      font-size: 0.75rem;
    }
  }
</style>


<style is:global>
  /* Repository badge colors */
  .repo-badge {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .repo-badge[data-repo="sdk-python"] {
    background: rgba(16, 185, 129, 0.15);
    color: var(--color-python);
  }

  .repo-badge[data-repo="sdk-typescript"] {
    background: rgba(16, 185, 129, 0.15);
    color: var(--color-typescript);
  }

  .repo-badge[data-repo="tools"] {
    background: rgba(16, 185, 129, 0.15);
    color: var(--color-tools);
  }

  .repo-badge[data-repo="agentcore-python"] {
    background: rgba(167, 139, 250, 0.15);
    color: var(--color-agentcore-python);
  }

  .repo-badge[data-repo="agentcore-typescript"] {
    background: rgba(167, 139, 250, 0.15);
    color: var(--color-agentcore-typescript);
  }
</style>
